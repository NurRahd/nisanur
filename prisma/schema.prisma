generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Profile {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        Int      @id @default(autoincrement())
  platform  String   @unique
  label     String
  value     String
  href      String
  iconType  String   @default("image")
  iconName  String?
  iconImage String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillGroup {
  id     Int     @id @default(autoincrement())
  title  String
  order  Int     @default(0)
  skills Skill[]
}

model Skill {
  id           Int        @id @default(autoincrement())
  name         String
  iconType     String     @default("lucide")
  iconName     String?
  iconImage    String?
  order        Int        @default(0)
  skillGroup   SkillGroup @relation(fields: [skillGroupId], references: [id], onDelete: Cascade)
  skillGroupId Int
}

model Experience {
  id          Int      @id @default(autoincrement())
  period      String
  duration    String
  title       String
  institution String
  bullets     String[]
  skills      String[]
  logoImage   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Education {
  id        Int      @id @default(autoincrement())
  school    String
  degree    String
  period    String
  score     String
  logoImage String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certificate {
  id            Int      @id @default(autoincrement())
  name          String
  issuer        String
  certificateId String
  issued        String
  expires       String
  file          String?
  image         String?
  imagePos      String   @default("50% 50%")
  imageFit      String   @default("cover")
  imageZoom     Float    @default(1)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Activity {
  id          Int             @id @default(autoincrement())
  title       String
  date        String
  description String
  longDesc    String
  details     String[]
  tags        String[]
  order       Int             @default(0)
  images      ActivityImage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ActivityImage {
  id         Int      @id @default(autoincrement())
  src        String
  pos        String   @default("50% 50%")
  order      Int      @default(0)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int
}

model Project {
  id        Int            @id @default(autoincrement())
  title     String
  desc      String
  longDesc  String
  features  String[]
  tags      String[]
  cat       String
  pos       String         @default("50% 50%")
  github    String?
  demo      String?
  image     String?
  images    ProjectImage[]
  featured  Boolean        @default(false)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  src       String
  pos       String  @default("50% 50%")
  order     Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
